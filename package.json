{
  "name": "aria-executive-assistant",
  "version": "2.0.0",
  "description": "AI-powered executive assistant — email triage, calendar scheduling, copilot chat",
  "main": "src/server.js",
  "scripts": {
    "start":        "node src/server.js",
    "dev":          "nodemon src/server.js",
    "lint":         "find src -name '*.js' -print0 | xargs -0 node --check && echo '✓ All files ok'",
    "docker:up":    "docker-compose up -d",
    "docker:down":  "docker-compose down",
    "docker:logs":  "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "setup:db":     "node scripts/setup-db.js"
  },
  "dependencies": {
    "bullmq":             "^5.4.0",
    "compression":        "^1.7.4",
    "connect-redis":      "^7.1.0",
    "cookie-parser":      "^1.4.6",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session":    "^1.18.0",
    "googleapis":         "^140.0.0",
    "groq-sdk":           "^0.9.0",
    "helmet":             "^7.1.0",
    "ioredis":            "^5.3.2",
    "pg":                 "^8.11.5",
    "uuid":               "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
